      <Text fill="#1a3e82" layoutX="171.0" layoutY="166.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text1-Update" text="Name:" />
      <Text layoutX="169.0" layoutY="220.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text1-Update" text="Email:" />
      <Text layoutX="169.0" layoutY="271.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text1-Update" text="Type:" />
      <Text fx:id="type_text" fill="#1c3b6e" layoutX="301.0" layoutY="271.0" strokeType="OUTSIDE" strokeWidth="0.0" wrappingWidth="81.0" />

      <TextField fx:id="UpdateProfile_username" layoutX="301.0" layoutY="149.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="Username" styleClass="textfield" />
