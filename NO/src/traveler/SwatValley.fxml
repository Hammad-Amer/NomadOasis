<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="anchor-paneSwatValley" stylesheets="@ViewDestinations.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="traveler.TravelerMainPageController">
