<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="main-background" stylesheets="@TravelerMainPage.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="traveler.TravelerEditProfileController">
   <children>
      <Button fx:id="goback_Main" layoutX="41.0" layoutY="41.0" mnemonicParsing="false" onAction="#goBackTravelerMain" prefHeight="43.0" prefWidth="149.0" text="Back" />
      <Button fx:id="ProfileEdit" layoutX="320.0" layoutY="401.0" mnemonicParsing="false" onAction="#editedProfile" prefHeight="50.0" prefWidth="161.0" text="Update" />

      <!-- Labels for Text Fields -->
      <Text layoutX="171.0" layoutY="166.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Name:" />
      <Text layoutX="173.0" layoutY="221.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email:" />
      <Text layoutX="176.0" layoutY="272.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Type:" />
      <Text fx:id="type_text" layoutX="309.0" layoutY="272.0" strokeType="OUTSIDE" strokeWidth="0.0" />
      <Text layoutX="177.0" layoutY="326.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Info:" />

      <!-- Text Fields -->
      <TextField fx:id="UpdateProfile_username" layoutX="301.0" layoutY="149.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="Username" styleClass="textfield" />
      <TextField fx:id="UpdateProfile_Email" layoutX="301.0" layoutY="204.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="Emailbox" styleClass="textfield" />
      <TextField fx:id="UpdateProfile_Info" layoutX="301.0" layoutY="309.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="ProfileInfo" styleClass="textfield" />
   </children>
</AnchorPane>
