<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="main-background" stylesheets="@TravelerMainPage.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="traveler.TravelerContactUsController">
   <children>
      <Button fx:id="goback_Main" layoutX="41.0" layoutY="41.0" mnemonicParsing="false" onAction="#goBackTravelerMain" prefHeight="43.0" prefWidth="99.0" text="Back" />
      <Button fx:id="QuerySubmit" layoutX="320.0" layoutY="423.0" mnemonicParsing="false" onAction="#submitQuery" prefHeight="50.0" prefWidth="161.0" text="Submit" />
      <Text fill="#2e4053" layoutX="168.0" layoutY="155.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-contact" text="Name:" />
      <Text layoutX="169.0" layoutY="210.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-contact" text="Email:" />
      <Text layoutX="166.0" layoutY="277.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="text-contact" text="Query:" />
      <TextField fx:id="ContactUs_username" layoutX="298.0" layoutY="138.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="Name" styleClass="textfield" />
      <TextField fx:id="ContactUs_Email" layoutX="298.0" layoutY="193.0" maxHeight="30.0" maxWidth="220.0" prefHeight="25.0" prefWidth="220.0" promptText="Email" styleClass="textfield" />
      <TextField fx:id="ContactUs_Query" alignment="TOP_LEFT" layoutX="298.0" layoutY="264.0" maxHeight="99.0" maxWidth="258.0" prefHeight="99.0" prefWidth="258.0" promptText="Enter Your Query Here" styleClass="textfield" />
      <Button fx:id="response" layoutX="658.0" layoutY="34.0" mnemonicParsing="false" onAction="#openResponsePage" prefHeight="50.0" prefWidth="67.0" styleClass="button-response" />
      <Label layoutX="228.0" layoutY="33.0" prefHeight="51.0" prefWidth="328.0" styleClass="view-package2s-label" stylesheets="@ViewPackages.css" text="Contact Consultant" textFill="#c5baba" />

   </children>
</AnchorPane>
